# DeepSeek API Key (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Email Send binding — configure via `npx wrangler email sending enable guoshaotech.com`
# No API key needed; the EMAIL binding is configured in wrangler.toml
# See: https://developers.cloudflare.com/email-service/

# Internal API auth secret
INTERNAL_SECRET=change-me-to-a-random-string
