{
  "name": "trend-catcher",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create trend-catcher-db",
    "db:migrate": "wrangler d1 execute trend-catcher-db --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute trend-catcher-db --local --file=./src/db/schema.sql",
    "test:scrapers": "npx tsx scripts/test-scrapers.ts",
    "it-test": "npx tsx scripts/it-test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.1.13",
    "ai": "^4.1.37",
    "cheerio": "^1.0.0",
    "hono": "^4.6.16",
    "resend": "^4.1.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.11",
    "@cloudflare/workers-types": "^4.20250505.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.7.3",
    "undici": "^8.3.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0"
  }
}
